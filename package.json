{
  "name": "o-apocalipse-do-delivery",
  "version": "1.0.0",
  "description": "Checkout legado para exercicio de analise, BDD e TDD.",
  "main": "src/server.js",
  "scripts": {
    "test": "jest --runInBand",
    "test:bdd": "cucumber-js",
    "test:mutation": "stryker run",
    "start": "node src/server.js",
    "start:gateway-stub": "node src/gateway-stub/server.js",
    "perf:load": "k6 run tests/performance/black-friday-load.js",
    "perf:stress": "k6 run tests/performance/black-friday-stress.js",
    "perf:herd": "k6 run tests/performance/thundering-herd-cache-flush.js",
    "perf:herd:local": "k6 run -e HERD_VUS=100 tests/performance/thundering-herd-cache-flush.js",
    "perf:gateway-slow": "k6 run tests/performance/gateway-lento-5000ms.js",
    "chaos:up": "docker compose up -d --build",
    "chaos:down": "docker compose down -v",
    "chaos:gateway-slow": "node chaos/toxics.js gateway-slow",
    "chaos:gateway-reset": "node chaos/toxics.js gateway-reset",
    "chaos:cache-down": "node chaos/toxics.js cache-down",
    "chaos:cache-up": "node chaos/toxics.js cache-up",
    "chaos:reset": "node chaos/toxics.js reset-all",
    "chaos:mttr": "node chaos/mttr.js gateway-slow",
    "chaos:mttr:cache": "node chaos/mttr.js cache-down"
  },
  "dependencies": {
    "express": "^4.19.2",
    "redis": "^4.7.1"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.9.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
